# Firebase configuration - replace with your project's credentials
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
FIREBASE_SERVICE_ACCOUNT_KEY={"key":"your-service-account-key"}

# IA Configuration (DeepSeek por defecto en todo el sistema)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional: modelo global para sugerencias, análisis de imágenes y resúmenes
# Si falta, usa deepseek-v4-flash por defecto
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional: model selector para /api/church-chat
# Si falta, app usa deepseek-v4-flash
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# PWA Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Sentry Configuration - Optimized for Performance
# Set SENTRY_ENABLED=false to disable Sentry entirely (optional)
SENTRY_ENABLED=true

# Get these values from your Sentry project settings
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=tu-org-slug
SENTRY_PROJECT=tu-project-slug
